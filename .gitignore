# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Tauri (Rust 编译产物 + 自动生成代码)
/src-tauri/target/
/src-tauri/gen/
/src-tauri/icons/logo-converted.png
/src-tauri/icons/logo-square.png

# Tauri 生成的临时图标源
/app-icon.png

# .env.production (生产机密，模板文件 .example 可以提交)
.env.production
